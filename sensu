
⸻

1. List running containers

docker ps --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}'

⸻

2. Find Docker Compose working directory

docker inspect <FRONTEND_CONTAINER> \
  --format='WorkingDir={{index .Config.Labels "com.docker.compose.project.working_dir"}}
ComposeFile={{index .Config.Labels "com.docker.compose.project.config_files"}}
Project={{index .Config.Labels "com.docker.compose.project"}}'

⸻

3. Go to compose directory

cd <COMPOSE_WORKING_DIRECTORY>
pwd
ls -la

⸻

4. Find compose files

find . -maxdepth 2 -type f \( \
  -name '*compose*.yml' -o \
  -name '*compose*.yaml' -o \
  -name 'docker-compose.yml' -o \
  -name 'docker-compose.yaml' \
\) -print

⸻

5. View compose file

cat <COMPOSE_FILE_NAME>

Before sharing the output, replace sensitive values like this:

<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/<REPOSITORY>:<TAG>
<INTERNAL_DOMAIN>
<PRIVATE_IP>
<SECRET_VALUE>
<DB_URL>

⸻

6. Inspect image, command, ports for all containers

for c in <NGINX_CONTAINER> <FRONTEND_CONTAINER> <BACKEND_CONTAINER>; do
  echo "===== $c ====="
  docker inspect "$c" \
    --format='Image={{.Config.Image}}
Entrypoint={{json .Config.Entrypoint}}
Cmd={{json .Config.Cmd}}
WorkingDir={{.Config.WorkingDir}}
RestartPolicy={{json .HostConfig.RestartPolicy}}
ExposedPorts={{json .Config.ExposedPorts}}
PortBindings={{json .HostConfig.PortBindings}}'
  echo
done

⸻

7. Check environment variables with secrets masked

for c in <NGINX_CONTAINER> <FRONTEND_CONTAINER> <BACKEND_CONTAINER>; do
  echo "===== $c ENV ====="
  docker inspect "$c" \
    --format='{{range .Config.Env}}{{println .}}{{end}}' \
    | sort \
    | sed -E 's/(PASSWORD|PASS|SECRET|TOKEN|KEY|CREDENTIAL|ACCESS_KEY|PRIVATE_KEY|DB_URL|DATABASE_URL|USERNAME|USER)=.*/\1=***MASKED***/I'
  echo
done

⸻

8. Check nginx routing config

docker exec <NGINX_CONTAINER> nginx -T 2>/dev/null \
  | grep -nE "server_name|listen|location|proxy_pass|upstream|root|try_files" -A5 -B5

⸻

9. Check full nginx config

Only share this after redacting internal domains, IPs, and paths if needed.

docker exec <NGINX_CONTAINER> nginx -T 2>/dev/null

⸻

10. Check frontend runtime

docker exec <FRONTEND_CONTAINER> sh -lc '
pwd
ps -ef
ls -la
cat package.json 2>/dev/null || true
'

⸻

11. Check backend runtime

docker exec <BACKEND_CONTAINER> sh -lc '
pwd
ps -ef
ls -la
'

⸻

12. Test nginx to frontend connectivity

docker exec <NGINX_CONTAINER> sh -lc \
'wget -S -O- http://<FRONTEND_CONTAINER>:3000 2>&1 | head -40 || true'

⸻

13. Test nginx to backend connectivity

docker exec <NGINX_CONTAINER> sh -lc \
'wget -S -O- http://<BACKEND_CONTAINER>:8080 2>&1 | head -40 || true'

If backend uses a different port, replace 8080.

