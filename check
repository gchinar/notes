#!/usr/bin/env python3
"""
build_redis_compare_dashboard.py

Create a CloudWatch dashboard that compares two ElastiCache (Valkey/Redis)
replication groups side by side -- e.g. an OLD cluster vs a NEW one you cut
over to during a production deployment.

What it does:
  * Auto-discovers each replication group's member nodes, so it adapts to
    2-node vs 4-node clusters with no hardcoding.
  * Reads each cluster's real node type and engine version and puts them in a
    header, so the dashboard is self-documenting and accurate.
  * Builds one widget per metric with OLD (blue) and NEW (orange) plotted
    TOGETHER, aggregated across each cluster's nodes via metric math.
  * Calls cloudwatch put-dashboard.

Safety: everything it reads is read-only. The ONLY write is creating/replacing
the named dashboard. Uses the AWS CLI under the hood (no boto3 needed) -- you
just need `aws` configured with CloudWatch + ElastiCache read + PutDashboard.

Usage:
  ./build_redis_compare_dashboard.py \
      --old-rg <old-replication-group-id> \
      --new-rg <new-replication-group-id> \
      --region <region>            # default us-east-1
      [--name <dashboard-name>]
      [--old-label "..."] [--new-label "..."]
"""
import argparse
import json
import subprocess
import sys
import tempfile

OLD_COLOR = "#1f77b4"   # blue
NEW_COLOR = "#ff7f0e"   # orange

# metric_name, widget title, per-node statistic, cross-node aggregation, y-axis label
METRICS = [
    ("NetworkBandwidthOutAllowanceExceeded", "Net Bandwidth OUT Allowance Exceeded  <-- KEY", "Sum", "SUM", "Count (shaped)"),
    ("NetworkBytesOut",                       "Network Bytes Out (cluster total)",             "Average", "SUM", "Bytes"),
    ("NetworkBandwidthInAllowanceExceeded",  "Net Bandwidth IN Allowance Exceeded",           "Sum", "SUM", "Count (shaped)"),
    ("NetworkBytesIn",                        "Network Bytes In (cluster total)",              "Average", "SUM", "Bytes"),
    ("NetworkPacketsPerSecondAllowanceExceeded", "PPS Allowance Exceeded",                     "Sum", "SUM", "Count"),
    ("NetworkConntrackAllowanceExceeded",    "Conntrack Allowance Exceeded",                  "Sum", "SUM", "Count"),
    ("EngineCPUUtilization",                  "Engine CPU %  (max node - single-thread)",      "Average", "MAX", "Percent"),
    ("CPUUtilization",                        "Host CPU %  (max node)",                        "Average", "MAX", "Percent"),
    ("Evictions",                             "Evictions (cluster total)",                     "Sum", "SUM", "Count"),
    ("DatabaseMemoryUsagePercentage",         "Memory Used %  (max node)",                     "Average", "MAX", "Percent"),
    ("FreeableMemory",                        "Freeable Memory  (min node)",                   "Average", "MIN", "Bytes"),
    ("CurrConnections",                       "Current Connections (cluster total)",           "Average", "SUM", "Count"),
    ("SuccessfulReadRequestLatency",          "Read Latency  (avg)",                           "Average", "AVG", "Microseconds"),
    ("SuccessfulWriteRequestLatency",         "Write Latency  (avg)",                          "Average", "AVG", "Microseconds"),
    ("ReplicationLag",                        "Replication Lag  (max node)",                   "Average", "MAX", "Seconds"),
]


def aws_json(args):
    proc = subprocess.run(["aws", *args, "--output", "json"],
                          capture_output=True, text=True)
    if proc.returncode != 0:
        sys.exit(f"ERROR: `aws {' '.join(args)}` failed:\n{proc.stderr.strip()}")
    return json.loads(proc.stdout or "{}")


def describe_cluster(rg_id, region):
    """Return (member_node_ids, node_type, engine_version) for a replication group."""
    data = aws_json(["elasticache", "describe-replication-groups",
                     "--replication-group-id", rg_id, "--region", region])
    groups = data.get("ReplicationGroups", [])
    if not groups:
        sys.exit(f"ERROR: replication group not found: {rg_id}")
    g = groups[0]
    nodes = g.get("MemberClusters", [])
    if not nodes:
        sys.exit(f"ERROR: no member nodes found for {rg_id}")
    node_type = g.get("CacheNodeType", "n/a")
    # engine version isn't always on the RG object; read it from a member node (best effort)
    version = "n/a"
    try:
        cc = aws_json(["elasticache", "describe-cache-clusters",
                       "--cache-cluster-id", nodes[0], "--region", region])
        clusters = cc.get("CacheClusters", [])
        if clusters:
            engine = clusters[0].get("Engine", "")
            version = f"{engine} {clusters[0].get('EngineVersion', '')}".strip()
    except SystemExit:
        pass
    return nodes, node_type, version


def raw_metric(metric_name, node, mid, stat):
    return ["AWS/ElastiCache", metric_name, "CacheClusterId", node,
            {"id": mid, "stat": stat, "visible": False}]


def metric_widget(title, metric_name, per_node_stat, agg, ylabel, region,
                  old_nodes, new_nodes, old_label, new_label):
    metrics, old_ids, new_ids = [], [], []
    for i, node in enumerate(old_nodes):
        mid = f"o{i}"; old_ids.append(mid)
        metrics.append(raw_metric(metric_name, node, mid, per_node_stat))
    metrics.append([{"expression": f"{agg}([{','.join(old_ids)}])",
                     "label": old_label, "id": "e_old", "color": OLD_COLOR}])
    for i, node in enumerate(new_nodes):
        mid = f"n{i}"; new_ids.append(mid)
        metrics.append(raw_metric(metric_name, node, mid, per_node_stat))
    metrics.append([{"expression": f"{agg}([{','.join(new_ids)}])",
                     "label": new_label, "id": "e_new", "color": NEW_COLOR}])
    return {
        "type": "metric",
        "properties": {
            "title": title,
            "region": region,
            "view": "timeSeries",
            "stacked": False,
            "period": 60,
            "yAxis": {"left": {"label": ylabel, "showUnits": False}},
            "metrics": metrics,
        },
    }


def hitrate_widget(region, old_nodes, new_nodes, old_label, new_label):
    metrics = []

    def side(nodes, prefix, label, color):
        h, m = [], []
        for i, node in enumerate(nodes):
            metrics.append(raw_metric("CacheHits", node, f"{prefix}h{i}", "Sum")); h.append(f"{prefix}h{i}")
        for i, node in enumerate(nodes):
            metrics.append(raw_metric("CacheMisses", node, f"{prefix}m{i}", "Sum")); m.append(f"{prefix}m{i}")
        hs, ms = f"SUM([{','.join(h)}])", f"SUM([{','.join(m)}])"
        # +1 in denominator guards against divide-by-zero when a cluster is idle
        metrics.append([{"expression": f"100*{hs}/({hs}+{ms}+1)",
                         "label": label, "id": f"hr_{prefix}", "color": color}])

    side(old_nodes, "o", old_label, OLD_COLOR)
    side(new_nodes, "n", new_label, NEW_COLOR)
    return {
        "type": "metric",
        "properties": {
            "title": "Cache Hit Rate %  (cluster)",
            "region": region, "view": "timeSeries", "period": 60,
            "yAxis": {"left": {"label": "Percent", "showUnits": False, "min": 0, "max": 100}},
            "metrics": metrics,
        },
    }


def build_dashboard(region, old, new, old_label, new_label):
    (old_nodes, old_type, old_ver) = old
    (new_nodes, new_type, new_ver) = new

    header_md = (
        f"# Redis / Valkey Deployment Comparison\n"
        f"**Blue = OLD**  ·  **Orange = NEW**  ·  all widgets aggregate across each cluster's nodes\n\n"
        f"| | OLD | NEW |\n|---|---|---|\n"
        f"| Engine / version | {old_ver} | {new_ver} |\n"
        f"| Node type | {old_type} | {new_type} |\n"
        f"| Nodes | {len(old_nodes)} | {len(new_nodes)} |\n\n"
        f"**Headline check:** *Net Bandwidth OUT Allowance Exceeded* should fall toward **0** on NEW "
        f"(larger nodes raise the network baseline). If it's still climbing, the bottleneck isn't node size."
    )
    widgets = [{"type": "text", "x": 0, "y": 0, "width": 24, "height": 5,
                "properties": {"markdown": header_md}}]

    panels = [metric_widget(t, m, s, a, y, region, old_nodes, new_nodes, old_label, new_label)
              for (m, t, s, a, y) in METRICS]
    panels.append(hitrate_widget(region, old_nodes, new_nodes, old_label, new_label))

    x, y, col = 0, 5, 0
    for p in panels:
        p["x"] = 0 if col == 0 else 12
        p["y"] = y
        p["width"] = 12
        p["height"] = 6
        col ^= 1
        if col == 0:
            y += 6
    return {"widgets": widgets}


def put_dashboard(name, body, region):
    with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False) as f:
        json.dump(body, f)
        path = f.name
    out = aws_json(["cloudwatch", "put-dashboard",
                    "--dashboard-name", name,
                    "--dashboard-body", f"file://{path}",
                    "--region", region])
    msgs = out.get("DashboardValidationMessages", [])
    if msgs:
        print("Validation messages from CloudWatch:")
        for m in msgs:
            print(f"  - {m}")
    return path


def main():
    ap = argparse.ArgumentParser(description="Generate a CloudWatch dashboard comparing two ElastiCache clusters.")
    ap.add_argument("--old-rg", required=True, help="OLD replication group id")
    ap.add_argument("--new-rg", required=True, help="NEW replication group id")
    ap.add_argument("--region", default="us-east-1")
    ap.add_argument("--name", default="redis-valkey-old-vs-new")
    ap.add_argument("--old-label", default=None, help="Legend label for OLD (defaults to id + node type)")
    ap.add_argument("--new-label", default=None, help="Legend label for NEW (defaults to id + node type)")
    args = ap.parse_args()

    print(f"Discovering nodes in {args.region} ...")
    old = describe_cluster(args.old_rg, args.region)
    new = describe_cluster(args.new_rg, args.region)
    old_label = args.old_label or f"OLD: {args.old_rg} ({old[1]} x{len(old[0])})"
    new_label = args.new_label or f"NEW: {args.new_rg} ({new[1]} x{len(new[0])})"
    print(f"  OLD {args.old_rg}: {len(old[0])} node(s), {old[1]}, {old[2]}")
    print(f"  NEW {args.new_rg}: {len(new[0])} node(s), {new[1]}, {new[2]}")

    body = build_dashboard(args.region, old, new, old_label, new_label)
    path = put_dashboard(args.name, body, args.region)

    url = (f"https://{args.region}.console.aws.amazon.com/cloudwatch/home"
           f"?region={args.region}#dashboards/dashboard/{args.name}")
    print(f"\nDashboard '{args.name}' created/updated.")
    print(f"Open it: {url}")
    print(f"(dashboard JSON written to {path} if you want to version-control it)")


if __name__ == "__main__":
    main()
