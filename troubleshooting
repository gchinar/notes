kubectl -n nebula-stack exec deploy/orion-worker -- sh -c 'cd /app/worker && node -e "
const Redis = require(\"ioredis\");
const r = new Redis({
  host: process.env.REDIS_HOST || \"ember-cache\",
  port: Number(process.env.REDIS_PORT || 6379),
  password: process.env.REDIS_AUTH || undefined
});
(async () => {
  console.log(\"PING:\", await r.ping());
  const big = await r.eval(\"return string.rep(\\\"x\\\",200000)\", 0);
  console.log(\"200KB reply OK:\", big.length);
  process.exit(0);
})().catch(e => {
  console.error(\"FAIL:\", e.message);
  process.exit(1);
});
"'
kubectl -n nebula-stack get po -o wide | grep -E 'worker|ember-cache|web'
kubectl get nodes --sort-by=.metadata.creationTimestamp
NODE=$(kubectl -n nebula-stack get po -l app=ember-cache -o jsonpath='{.items[0].spec.nodeName}')
kubectl -n nebula-stack patch deploy orion-worker -p "{\"spec\":{\"template\":{\"spec\":{\"nodeSelector\":{\"kubernetes.io/hostname\":\"$NODE\"}}}}}"
kubectl -n nebula-stack set env deploy/orion-worker REDIS_ENABLE_AUTO_PIPELINING=false
kubectl -n nebula-stack set env deploy/orion-web REDIS_ENABLE_AUTO_PIPELINING=false
kubectl -n nebula-stack exec deploy/ember-cache -- sh -c 'for q in $(valkey-cli --scan --pattern "bull:*:wait"); do echo -n "$q = "; valkey-cli llen "$q"; done'
curl -si -u "pk-owl-REAL:sk-owl-REAL" -X POST https://quartz-river.example.com/api/public/ingestion \
  -H 'Content-Type: application/json' \
  -d '{"batch":[{"id":"evt-random-1","type":"trace-create","timestamp":"2026-07-01T04:00:00.000Z","body":{"id":"trace-random-1","name":"smoke-test","timestamp":"2026-07-01T04:00:00.000Z"}}]}'
kubectl -n nebula-stack exec slatehouse-0 -- clickhouse-client --query "SELECT id,name FROM traces WHERE id='trace-random-1'"
kubectl -n nebula-stack logs deploy/orion-worker | grep -i clickhouse
kubectl -n nebula-stack logs slatehouse-0
kubectl -n nebula-stack rollout restart deploy/orion-worker
kubectl -n nebula-stack rollout restart deploy/orion-web
kubectl -n nebula-stack rollout status deploy/orion-worker
kubectl -n nebula-stack rollout status deploy/orion-web
